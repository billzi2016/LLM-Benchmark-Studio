# ==================== Django ====================
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=replace-with-a-local-secret
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DJANGO_PORT=6341
FRONTEND_PORT=6342
FRONTEND_ALLOWED_ORIGINS=http://localhost:6342
CSRF_TRUSTED_ORIGINS=http://localhost:6342
VITE_API_BASE_URL=http://localhost:6341

# ==================== PostgreSQL ====================
# Docker Compose uses postgres:5432 internally and exposes it as localhost:55432.
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_HOST_PORT=55432
POSTGRES_DB=llm_benchmark_studio
POSTGRES_USER=llm_benchmark
POSTGRES_PASSWORD=replace-with-postgres-password
POSTGRES_SSL_MODE=disable

# ==================== RabbitMQ ====================
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=replace-with-rabbitmq-password
RABBITMQ_VHOST=/
RABBITMQ_URL=amqp://guest:replace-with-rabbitmq-password@localhost:5672//

# ==================== Celery ====================
CELERY_BROKER_URL=amqp://guest:replace-with-rabbitmq-password@localhost:5672//
CELERY_RESULT_BACKEND=django-db
CELERY_TASK_DEFAULT_QUEUE=llm_benchmark.serial
CELERY_WORKER_CONCURRENCY=1
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_TASK_ACKS_LATE=true
CELERY_TASK_REJECT_ON_WORKER_LOST=true

# ==================== LLM Provider Selection ====================
DEFAULT_PROVIDER=ollama
JUDGE_PROVIDER=ollama
JUDGE_MODEL=gpt-oss:20b
TRANSLATE_PROVIDER=ollama
TRANSLATE_MODEL=gpt-oss:20b
LLM_CONTEXT_THINK=65536
LLM_CONTEXT_NO_THINK=16384
LLM_PROVIDER_TIMEOUT_SECONDS=120

# ==================== Provider: Ollama ====================
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_DOCKER_BASE_URL=http://host.docker.internal:11434
OLLAMA_TIMEOUT_SECONDS=120

# ==================== Provider: OpenAI ====================
OPENAI_ENABLED=false
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace-with-openai-api-key

# ==================== Provider: OpenRouter ====================
OPENROUTER_ENABLED=false
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=replace-with-openrouter-api-key

# ==================== Provider: vLLM OpenAI-Compatible ====================
VLLM_ENABLED=false
VLLM_HOST=localhost
VLLM_PORT=8000
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=

# ==================== Provider: SGLang OpenAI-Compatible ====================
SGLANG_ENABLED=false
SGLANG_HOST=localhost
SGLANG_PORT=30000
SGLANG_BASE_URL=http://localhost:30000/v1
SGLANG_API_KEY=

# ==================== Provider: Custom FastAPI Transformer OpenAI-Compatible ====================
OPENAI_COMPATIBLE_ENABLED=false
OPENAI_COMPATIBLE_HOST=localhost
OPENAI_COMPATIBLE_PORT=6328
OPENAI_COMPATIBLE_BASE_URL=http://localhost:6328/v1
OPENAI_COMPATIBLE_API_KEY=
